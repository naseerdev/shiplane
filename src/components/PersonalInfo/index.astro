---
import { Trail } from "../../lib/icons/Trail";
import { Callback } from "../../lib/icons/Callback";
import { Email } from "../../lib/icons/Email";
---

<div class="mt-10 md:mt-11 container mx-auto px-[10px] sm:px-[0px]">
  <div>
    <p class="text-[2.1rem] sm:text-5xl mt-2 leading-[50px] text-center text-main font-extrabold dark:text-white">
      Want To <span class="bg-[#FFF0D9] dark:bg-primary"> talk with us</span>
    </p>
    <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-8 text-main dark:text-white">
      We're always happy to help! There are 2 easy ways to start a conversation:
    </p>
    <!-- mt-20 gap-5 px-5 -->
    <div class="flex flex-col md:flex-row justify-center items-center mt-[2rem] gap-5 px-5 s">
      <div class="flex flex-col w-full md:w-72 text-center">
        <div class="mx-auto"><Trail /></div>
        <p class="text-[22px] sm:text-[24px] lg:text-[26px] font-bold text-main dark:text-white mt-4">Start free trial</p>
      </div>
      <div class="flex flex-col w-full md:w-72 text-center">
        <div class="mx-auto"><Callback /></div>
        <p class="text-[22px] sm:text-[24px] lg:text-[26px] font-bold text-main dark:text-white mt-4">Request a Callback</p>
      </div>
      <div class="flex flex-col w-full md:w-72 text-center relative">
        <div class="absolute right-[27px] top-[-20px] rounded-full bg-primary dark:bg-white h-[14px] w-[14px]"></div>
        <div class="mx-auto"><Email /></div>
        <p class="text-[22px] sm:text-[24px] lg:text-[26px] font-bold text-main dark:text-white mt-4">Email Support</p>
      </div>
    </div>
  </div>
</div>
