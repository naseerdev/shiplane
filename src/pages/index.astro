---
import Layout from "../layouts/Layout.astro";
import ShipmentTrack from "../components/ShipmentTrack/ShipmentTrack.astro";
import SmartFeatures from "../components/SmartFeature/SmartFeatures.astro";
import Analytics from "../components/Analytics/Analytics.astro";
import Carrier from "../components/Carrier/Carrier.astro";
import PricePlan from "../components/PricePlan/PricePlan";
import FaqSection from "../components/FAQ/FaqSection";
import GetStarted from "../components/GetStarted/GetStarted";
import Hero from "../components/header/Hero.astro";
---

<Layout title="Welcome to Astro.">
  <Hero />
  <ShipmentTrack />
  <SmartFeatures />
  <Analytics />
  <Carrier />
  <FaqSection client:only="solid-js" />
  <PricePlan client:only="solid-js" />
  <GetStarted client:only="solid-js" />
</Layout>
